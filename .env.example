# Frontend (Vite) environment.
# Copy to .env.local (or .env) for local development.

# Base URL of the EASIL backend (the server/ app).
# Local development example:
VITE_API_URL=http://localhost:4000

# For Vercel deployments, set this in the Vercel project settings
# to the URL of your deployed backend, for example:
# VITE_API_URL=https://your-backend-app.onrender.com
