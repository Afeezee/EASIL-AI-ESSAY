# ---- Server ----
PORT=4000
# Public base URL of THIS server (used to build file_url for uploads).
PUBLIC_URL=http://localhost:4000
# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGIN=http://localhost:5173

# ---- Database (Postgres) ----
# Any Postgres works. Easiest zero-install option: a free Neon database (https://neon.tech).
# Example: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/easil?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/easil
# Set to "true" when your provider requires SSL (Neon/Supabase/RDS do). Leave empty for local.
DATABASE_SSL=

# ---- Auth ----
# Long random string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ---- LLM (Groq) ----
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---- File uploads (optional: Vercel Blob) ----
# Leave empty for local dev (files upload through the server, capped at 4MB).
# On Vercel, create a Blob store (Storage -> Blob) and it auto-injects this token;
# uploads then go straight to Blob with no size limit.
BLOB_READ_WRITE_TOKEN=
